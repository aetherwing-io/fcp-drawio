{
  "name": "@aetherwing/fcp-drawio",
  "version": "0.2.9",
  "description": "MCP server for creating and editing draw.io diagrams through intent-level commands",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "fcp-drawio": "dist/index.js"
  },
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@aetherwing/fcp-core": "^0.1.17",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "elkjs": "^0.11.0",
    "fast-xml-parser": "^4.5.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.2",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/aetherwing-io/fcp-drawio"
  },
  "keywords": [
    "drawio",
    "diagrams",
    "architecture",
    "mcp",
    "fcp"
  ]
}
